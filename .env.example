TWITTER_BEARER_TOKEN=

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=

# Email SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# OpenAI API (optional)
OPENAI_API_KEY=
